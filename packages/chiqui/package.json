{
  "name": "chiqui",
  "version": "0.1.0",
  "description": "Content-driven SvelteKit SSG framework with i18n, mdsvex content pipeline, and DaisyUI components.",
  "type": "module",
  "license": "MIT",
  "author": "mrmx <mistermx@gmail.com>",
  "homepage": "https://github.com/mrmx/Chiqui#readme",
  "bugs": {
    "url": "https://github.com/mrmx/Chiqui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrmx/Chiqui.git",
    "directory": "packages/chiqui"
  },
  "keywords": [
    "sveltekit",
    "svelte",
    "ssg",
    "static-site-generator",
    "mdsvex",
    "i18n",
    "daisyui",
    "tailwindcss"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "svelte": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./content": {
      "types": "./dist/content.d.ts",
      "default": "./dist/content.js"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "default": "./dist/navigation.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./svelte-config": {
      "types": "./dist/svelte-config.d.ts",
      "default": "./dist/svelte-config.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "svelte-kit sync && svelte-package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "echo 'no tests yet'",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@iconify/svelte": "^5.0.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^6.1.1",
    "@sveltejs/kit": "^2.47.0",
    "@sveltejs/package": "^2.3.11",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "mdsvex": "^0.12.6",
    "svelte": "^5.40.1",
    "svelte-check": "^4.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
